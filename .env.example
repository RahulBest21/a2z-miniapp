# A2Z Bot — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Telegram Bot Token (from @BotFather)
A2Z_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Gemini API Keys (from https://aistudio.google.com/apikey)
# Comma-separated: GEMINI_KEYS=key1,key2,key3
# OR individual: GEMINI_KEY_1=xxx, GEMINI_KEY_2=yyy
GEMINI_KEYS=YOUR_GEMINI_KEY_HERE

# Optional: Lounge channel for PvP broadcasts
A2Z_LOUNGE_CHAT_ID=-100xxxxxxxxx

# Optional: Channel for membership verification
A2Z_CHANNEL_ID=@A2Zupdates4U
